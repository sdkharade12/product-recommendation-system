    "import os\n",
    "import numpy as np\n",
    "\n",
    "def get_meta_embeddings(df, model, path=\"../models/meta_embeddings.npy\"):\n",
    "    \n",
    "    # Step 1: Check if file exists\n",
    "    if os.path.exists(path):\n",
    "        print(\"Loading meta embeddings from file...\")\n",
    "        meta_embeddings = np.load(path)\n",
    "    \n",
    "    else:\n",
    "        print(\"Creating meta embeddings (first time)...\")\n",
    "        \n",
    "        meta_embeddings = model.encode(\n",
    "            df1['meta_text'].tolist(),\n",
    "            show_progress_bar=True\n",
    "        )\n",
    "        \n",
    "        # Create folder if not exists\n",
    "        os.makedirs(os.path.dirname(path), exist_ok=True)\n",
    "        \n",
    "        # Save embeddings\n",
    "        np.save(path, meta_embeddings)\n",
    "        print(\"Meta embeddings saved successfully!\")\n",
    "    \n",
    "    return meta_embeddings"
   ]
