    "def recommend_products(query, top_k=10):\n",
    "\n",
    "    # Step 1: Encode query\n",
    "    query_embedding = model.encode([query])\n",
    "    query_embedding = normalize(query_embedding)\n",
    "\n",
    "    # Step 2: Pre-filter using meta embeddings (TOP 200)\n",
    "    meta_scores = np.dot(meta_embeddings, query_embedding.T).flatten()\n",
    "    top_meta_indices = np.argsort(meta_scores)[::-1][:200]\n",
    "\n",
    "    filtered_product_embeddings = product_embeddings[top_meta_indices]\n",
    "\n",
    "    # Step 3: Final similarity on filtered set\n",
    "    final_scores = np.dot(filtered_product_embeddings, query_embedding.T).flatten()\n",
    "\n",
    "    # Boost based on title match\n",
    "    title_match = df1.iloc[top_meta_indices]['title'].str.contains(query, case=False).astype(int).values\n",
    "\n",
    "    # Boost based on brand presence\n",
    "    brand_match = df1.iloc[top_meta_indices]['brand'].str.contains(query, case=False).astype(int).values\n",
    "\n",
    "    # Final score combination\n",
    "    final_scores = final_scores + 0.2 * title_match + 0.1 * brand_match\n",
    "    top_indices = np.argsort(final_scores)[::-1][:top_k]\n",
    "\n",
    "    # Step 4: Map back to original dataframe\n",
    "    final_product_indices = [top_meta_indices[i] for i in top_indices]\n",
    "\n",
    "    return df1.iloc[final_product_indices][['title', 'category', 'brand']]"
   ]
  },
