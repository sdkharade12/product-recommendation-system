     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "'''data = []\n",
    "\n",
    "with gzip.open('../data/meta_Electronics.jsonl.gz', 'rt', encoding='utf-8') as f:\n",
    "    for line in f:\n",
    "        obj = json.loads(line)\n",
    "\n",
    "        data.append({\n",
    "            \"asin\": obj.get(\"parent_asin\"),\n",
    "            \"title\": obj.get(\"title\"),\n",
    "            \"brand\": obj.get(\"store\"),\n",
    "            \"category\": obj.get(\"categories\"),\n",
    "            \"description\": obj.get(\"description\"),\n",
    "            \"avg_rating\": obj.get(\"average_rating\"),\n",
    "            \"rating_count\": obj.get(\"rating_number\"),\n",
    "            \"bought_together\": obj.get(\"bought_together\")\n",
    "        })\n",
    "\n",
    "df_meta = pd.DataFrame(data)'''"
   ]
  },
